# Use the public npm registry only. No private/vendor registry — keep the toolchain
# reproducible anywhere in the world with zero lock-in (see docs/decisions/ADR-0001).
registry=https://registry.npmjs.org/

# pnpm: hoist as little as possible so package boundaries stay honest.
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true

# Provenance attestation on publish (supply-chain transparency for npm consumers).
provenance=true
